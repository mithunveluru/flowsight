# PostgreSQL
POSTGRES_PASSWORD=your_secure_password_here

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=your_base64_encoded_256bit_secret_here
JWT_EXPIRATION=86400000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3007

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080

# Password-reset email. Provider options: gmail, brevo, resend.
#
# gmail: SMTP with an App Password (Google account > Security > 2-Step
# Verification > App passwords). Good for local dev. Does NOT work on hosts
# that block outbound SMTP (e.g. Render free tier).
# Leave MAIL_USERNAME/MAIL_PASSWORD empty to log the reset link instead of sending.
EMAIL_PROVIDER=gmail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_16_char_app_password
# Optional: defaults to MAIL_USERNAME. Gmail rejects a From it does not own.
MAIL_FROM=FlowSight <your_gmail_address@gmail.com>
#
# brevo: transactional email over HTTPS (port 443), so it works where SMTP is
# blocked. Verify a single sender in the Brevo dashboard; no domain needed.
# To use it: set EMAIL_PROVIDER=brevo and fill the two vars below.
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=your_verified_sender@example.com
FRONTEND_URL=http://localhost:3007
