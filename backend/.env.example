# Database
DB_URL=jdbc:postgresql://localhost:5432/flowsight
DB_USERNAME=flowsight
DB_PASSWORD=your_secure_password_here

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=your_base64_encoded_256bit_secret_here
JWT_EXPIRATION=86400000

# CORS — comma-separated for multiple origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Password-reset email — Gmail SMTP with an App Password
# (Google account > Security > 2-Step Verification > App passwords).
# Leave MAIL_USERNAME/MAIL_PASSWORD empty to log the reset link instead of sending.
EMAIL_PROVIDER=gmail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_16_char_app_password
# Optional: defaults to MAIL_USERNAME. Gmail rejects a From it does not own.
MAIL_FROM=FlowSight <your_gmail_address@gmail.com>
FRONTEND_URL=http://localhost:3007
